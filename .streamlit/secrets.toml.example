# ============================================================
# Attendance BackOffice STT — Secrets Template
# Copia este archivo a secrets.toml (local) o pega en Streamlit Cloud
# ============================================================

# --- Google Service Account ---
# Descarga el JSON de tu service account y mapea aquí cada campo
[gcp_service_account]
type = "service_account"
project_id = "REEMPLAZAR"
private_key_id = "REEMPLAZAR"
private_key = "-----BEGIN PRIVATE KEY-----\nREEMPLAZAR\n-----END PRIVATE KEY-----\n"
client_email = "REEMPLAZAR@REEMPLAZAR.iam.gserviceaccount.com"
client_id = "REEMPLAZAR"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "REEMPLAZAR"
universe_domain = "googleapis.com"

# --- Google Sheet ---
GOOGLE_SHEET_ID = "REEMPLAZAR_CON_ID_DEL_SHEET"

# --- App ---
APP_URL = "https://attendance-backoffice-stt.streamlit.app/"
TIMEZONE = "America/Guatemala"

# --- Credenciales iniciales (solo para primera vez, luego se borran de aquí) ---
# Estas contraseñas se hashean al ejecutar seed.py por primera vez
[initial_users]
sofi_password = "STT_Sofi_2026!"
evelyn_password = "STT_Evelyn_2026!"
